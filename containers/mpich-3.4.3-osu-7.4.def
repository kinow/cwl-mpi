Bootstrap: docker
From: ubuntu:26.04

%post

    # Version values
    # 3.4a2 on LUMI
    VERSION=3.4.3
    BENCHMARK=7.4

    # Install software
    apt-get update

    apt-get install -y --no-install-recommends \
        file \
        g++ \
        gcc \
        gfortran \
        make \
        gdb \
        strace \
        wget \
        ca-certificates

    # Install MPICH
    wget -q "http://www.mpich.org/static/downloads/${VERSION}/mpich-${VERSION}.tar.gz"

    tar xf "mpich-${VERSION}.tar.gz"

    cd "mpich-${VERSION}"

    ./configure \
        --disable-fortran \
        --enable-fast=all,O3 \
        --prefix=/usr \
        --with-device=ch3

    make -j"$(nproc)"
    make install

    ldconfig

    cd ..

    # Build OSU Benchmarks
    wget -q \
        "http://mvapich.cse.ohio-state.edu/download/mvapich/osu-micro-benchmarks-${BENCHMARK}.tar.gz"

    tar xf "osu-micro-benchmarks-${BENCHMARK}.tar.gz"

    cd "osu-micro-benchmarks-${BENCHMARK}"

    ./configure \
        --prefix=/usr/local \
        CC="$(which mpicc)" \
        CFLAGS=-O3

    make
    make install

    cd ..

    rm -rf "osu-micro-benchmarks-${BENCHMARK}"
    rm "osu-micro-benchmarks-${BENCHMARK}.tar.gz"

%runscript

    /usr/local/libexec/osu-micro-benchmarks/mpi/pt2pt/osu_bw